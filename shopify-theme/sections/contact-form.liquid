{% comment %}
  Section: Contact Form
  KGS Home Decors - Premium Dark Luxury Theme
{% endcomment %}

<section id="contact" class="relative py-20 sm:py-28 lg:py-36 px-5 sm:px-6 md:px-12 bg-onyx-900 overflow-hidden">
  <div class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gold-500/3 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-[1400px] mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 sm:gap-16 lg:gap-20">
      <div class="reveal">
        <p class="text-gold-500 text-[10px] tracking-[0.4em] uppercase mb-5 font-sans font-medium">Get In Touch</p>
        <h2 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-display font-medium text-white mb-6 leading-[1.08]">{{ section.settings.contact_heading | default: "Let's Make Your Home Beautiful." }}</h2>
        <p class="text-sand-200/60 font-light text-[15px] sm:text-base mb-10 sm:mb-12 leading-[1.75]">Talk to us about what you need — we'll help you find the right decor.</p>
        
        <div class="space-y-8">
          <div class="flex gap-5 items-start">
            <span class="material-symbols-outlined text-gold-500 text-2xl flex-shrink-0 mt-0.5">location_on</span>
            <div>
              <h4 class="text-white text-sm tracking-[0.15em] uppercase mb-2 font-medium">Showroom</h4>
              <p class="text-sand-200/60 font-light leading-relaxed text-sm">{{ settings.showroom_address | default: 'Junction Road, near EB Office, Virudhachalam, Tamil Nadu' }}</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <span class="material-symbols-outlined text-gold-500 text-2xl flex-shrink-0 mt-0.5">call</span>
            <div>
              <h4 class="text-white text-sm tracking-[0.15em] uppercase mb-2 font-medium">Call Us</h4>
              <a href="tel:{{ settings.contact_phone | default: '+919789182921' }}" class="text-sand-200/60 font-light block hover:text-gold-400 transition-colors duration-500 text-sm min-h-[40px] flex items-center">{{ settings.contact_phone | default: '+91 97891 82921' }}</a>
              <a href="tel:+918489499166" class="text-sand-200/60 font-light block hover:text-gold-400 transition-colors duration-500 text-sm min-h-[40px] flex items-center">+91 84894 99166</a>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <span class="material-symbols-outlined text-gold-500 text-2xl flex-shrink-0 mt-0.5">schedule</span>
            <div>
              <h4 class="text-white text-sm tracking-[0.15em] uppercase mb-2 font-medium">Store Hours</h4>
              <p class="text-sand-200/60 font-light leading-relaxed text-sm">Open All Days<br>10:00 AM – 10:00 PM</p>
           销售渠道
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 mt-10">
          <a href="tel:{{ settings.contact_phone | default: '+919789182921' }}" class="btn-primary inline-flex items-center justify-center gap-2.5 bg-gold-500 text-onyx-900 px-7 py-4 text-[11px] tracking-[0.2em] uppercase font-semibold min-h-[50px]">
            <span class="material-symbols-outlined text-sm">call</span> Call Now
          </a>
          <a href="https://wa.me/{{ settings.contact_whatsapp | default: '919789182921' }}" target="_blank" class="btn-outline inline-flex items-center justify-center gap-2.5 border border-gold-500/25 text-gold-400 px-7 py-4 text-[11px] tracking-[0.2em] uppercase font-medium min-h-[50px]">
            <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51h-.57c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>

      <div class="bg-onyx-800/80 p-7 sm:p-10 lg:p-14 border border-onyx-600/40 reveal rounded-sm" style="box-shadow: 0 0 60px rgba(212,175,55,0.03);">
        <p class="text-gold-500/50 text-[10px] tracking-[0.3em] uppercase text-center mb-2 font-sans">Free · No Obligation</p>
        <h3 class="text-xl sm:text-2xl text-white font-display font-medium mb-7 sm:mb-8 text-center border-b border-onyx-600/50 pb-6" style="border-bottom-color: rgba(212,175,55,0.08);">Get Personalized Suggestions</h3>
        
        {% form 'contact', class: 'space-y-7' %}
          <input type="text" name="contact[name]" placeholder="Full Name" required
                 class="w-full bg-transparent border-b border-onyx-600/60 py-4 text-white font-light focus:outline-none focus:border-gold-500 transition-colors duration-500 placeholder-onyx-500 text-sm min-h-[48px]">
          <input type="tel" name="contact[phone]" placeholder="Phone Number" required
                 class="w-full bg-transparent border-b border-onyx-600/60 py-4 text-white font-light focus:outline-none focus:border-gold-500 transition-colors duration-500 placeholder-onyx-500 text-sm min-h-[48px]">
          <input type="text" name="contact[message]" placeholder="What are you looking for?"
                 class="w-full bg-transparent border-b border-onyx-600/60 py-4 text-white font-light focus:outline-none focus:border-gold-500 transition-colors duration-500 placeholder-onyx-500 text-sm min-h-[48px]">
          
          <button type="submit" class="btn-primary block w-full bg-gold-500 text-onyx-900 py-4 uppercase tracking-[0.2em] font-semibold text-center text-[11px] min-h-[50px] flex items-center justify-center mt-2">
            Get a Call Back
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Section",
  "tag": "section",
  "class": "section-contact",
  "settings": [
    {
      "type": "text",
      "id": "contact_heading",
      "default": "Let's Make Your Home Beautiful.",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "default": "+91 97891 82921",
      "label": "Phone Number"
    },
    {
      "type": "text",
      "id": "contact_whatsapp",
      "default": "919789182921",
      "label": "WhatsApp Number (without +)"
    }
  ],
  "presets": [
    {
      "name": "Contact Section"
    }
  ]
}
{% endschema %}