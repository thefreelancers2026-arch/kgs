{% comment %}
  Section: Hero
  KGS Home Decors - Premium Dark Luxury Theme
{% endcomment %}

{% style %}
  .hero-heading {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.15;
    color: var(--color-sand-50);
    position: relative;
    text-shadow: 0 0 80px rgba(212, 175, 55, 0.14), 0 2px 6px rgba(0,0,0,0.5);
    font-size: clamp(28px, 6vw, 56px);
  }
  @media (min-width: 1024px) {
    .hero-heading {
      font-weight: 700;
      letter-spacing: 0.005em;
      text-shadow: 0 0 120px rgba(212, 175, 55, 0.15), 0 0 40px rgba(212, 175, 55, 0.06);
    }
  }
  .hero-heading-glow {
    position: absolute;
    inset: -25%;
    background: radial-gradient(ellipse at center, rgba(212, 175, 55, 0.08) 0%, transparent 65%);
    pointer-events: none;
    z-index: -1;
  }
  .hero-italic {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    line-height: 1.3;
    padding: 0.15em 0.25em;
    background: linear-gradient(135deg, #F5E6B8 0%, #D4AF37 30%, #F2DCA5 60%, #D4AF37 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 5s ease-in-out infinite;
    filter: drop-shadow(0 0 30px rgba(212, 175, 55, 0.15));
    display: inline-block;
    font-size: clamp(22px, 5vw, 44px);
  }
  @media (min-width: 1024px) {
    .hero-italic {
      font-weight: 500;
      filter: drop-shadow(0 0 50px rgba(212, 175, 55, 0.2));
    }
  }
  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .hero-enter {
    opacity: 0;
    transform: translateY(12px);
    animation: heroFadeUp 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes heroFadeUp {
    0% { opacity: 0; transform: translateY(12px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .hero-delay-1 { animation-delay: 0.3s; }
  .hero-delay-2 { animation-delay: 0.6s; }
  .hero-delay-3 { animation-delay: 0.9s; }
  .hero-delay-4 { animation-delay: 1.2s; }
  .hero-delay-5 { animation-delay: 1.5s; }
  @keyframes slowPan {
    0% { transform: scale(1.0); }
    100% { transform: scale(1.12); }
  }
  .ambient-dot {
    position: absolute;
    width: 2px;
    height: 2px;
    background: rgba(212, 175, 55, 0.25);
    border-radius: 50%;
    animation: float 12s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px) translateX(0px); opacity: 0; }
    25% { opacity: 0.6; }
    50% { transform: translateY(-60px) translateX(20px); opacity: 0.3; }
    75% { opacity: 0.5; }
  }
  .sparkle-icon {
    animation: sparkleGlow 3s ease-in-out infinite alternate;
    filter: drop-shadow(0 0 3px rgba(212, 175, 55, 0.3));
  }
  @keyframes sparkleGlow {
    0% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.15); }
    100% { opacity: 0.7; transform: scale(1); }
  }
  .btn-primary {
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .btn-primary:hover::before { opacity: 1; }
  .btn-primary:hover { 
    transform: scale(1.03); 
    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.25); 
  }
  .btn-primary:active { transform: scale(0.98); }
  .btn-outline {
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    border-color: var(--color-gold-500);
    box-shadow: 0 0 20px rgba(212, 175, 55, 0.1);
    transform: scale(1.03);
  }
  .btn-outline:active { transform: scale(0.98); }
{% endstyle %}

<section class="relative min-h-[100svh] w-full flex items-center justify-center overflow-hidden pt-[72px] sm:pt-[90px] pb-[40px] sm:pb-[60px] px-4 sm:px-5">
  <div class="absolute inset-0 w-full h-full">
    {% if section.settings.hero_image != blank %}
      <img src="{{ section.settings.hero_image | image_url: width: 2000 }}" loading="eager" fetchpriority="high"
           class="w-full h-full object-cover opacity-50" 
           style="animation: slowPan 30s ease-in-out infinite alternate;"
           alt="{{ section.settings.hero_heading | default: 'Modern Indian living room with premium home decor' }}">
    {% else %}
      <img src="{{ 'hero_indian_interior.png' | asset_url }}" loading="eager" fetchpriority="high"
           class="w-full h-full object-cover opacity-50" 
           style="animation: slowPan 30s ease-in-out infinite alternate;"
           alt="Modern Indian living room with premium home decor">
    {% endif %}
    <div class="absolute inset-0 bg-gradient-to-b from-onyx-900/70 via-onyx-900/30 to-onyx-900"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-onyx-900/50 via-transparent to-onyx-900/50"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,#0A0A0A_85%)]"></div>
  </div>

  <div class="ambient-dot" style="top: 20%; left: 15%; animation-delay: 0s;"></div>
  <div class="ambient-dot" style="top: 60%; left: 75%; animation-delay: 3s;"></div>
  <div class="ambient-dot" style="top: 35%; left: 55%; animation-delay: 6s;"></div>
  <div class="ambient-dot" style="top: 75%; left: 30%; animation-delay: 9s;"></div>

  <div class="relative z-10 text-center px-0 sm:px-8 max-w-7xl w-full">
    <p class="hero-enter hero-delay-1 text-gold-500 text-[9px] sm:text-xs tracking-[0.35em] sm:tracking-[0.5em] uppercase mb-4 sm:mb-7 font-sans font-medium flex items-center justify-center gap-2 sm:gap-3">
      <svg class="sparkle-icon w-[10px] h-[10px] sm:w-[14px] sm:h-[14px] flex-shrink-0" viewBox="0 0 24 24" fill="none"><defs><linearGradient id="sparkleGrad1" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#E5C76B"/><stop offset="100%" stop-color="#D4AF37"/></linearGradient></defs><path d="M12 0L14.59 8.41L23 12L14.59 15.59L12 24L9.41 15.59L1 12L9.41 8.41L12 0Z" fill="url(#sparkleGrad1)" opacity="0.85"/></svg>
      <span>Home Decor Shop in Virudhachalam</span>
      <svg class="sparkle-icon w-[10px] h-[10px] sm:w-[14px] sm:h-[14px] flex-shrink-0" viewBox="0 0 24 24" fill="none"><defs><linearGradient id="sparkleGrad2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#E5C76B"/><stop offset="100%" stop-color="#D4AF37"/></linearGradient></defs><path d="M12 0L14.59 8.41L23 12L14.59 15.59L12 24L9.41 15.59L1 12L9.41 8.41L12 0Z" fill="url(#sparkleGrad2)" opacity="0.85"/></svg>
    </p>
    
    <div class="relative">
      <div class="hero-heading-glow"></div>
      <h1 class="hero-enter hero-delay-2 hero-heading mb-1 sm:mb-3">
        {{ section.settings.hero_heading | default: 'Make Your Home Look Beautiful' }}
      </h1>
      <p class="hero-enter hero-delay-3 hero-italic mb-5 sm:mb-8">
        {{ section.settings.hero_subheading | default: 'with Premium Decor.' }}
      </p>
    </div>
    
    <p class="hero-enter hero-delay-4 text-sand-200/80 text-[0.875rem] sm:text-lg md:text-xl font-light max-w-md sm:max-w-xl mx-auto mb-6 sm:mb-10 leading-[1.7] font-sans">
      {{ section.settings.hero_description | default: 'Furniture, Plants, Fountains & Stylish Decor — at our showroom in Virudhachalam.' }}
    </p>

    <div class="hero-enter hero-delay-5 w-full flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-5 max-w-sm sm:max-w-none mx-auto">
      <a href="{{ section.settings.hero_cta_link | default: '/collections' }}" class="btn-primary inline-flex items-center justify-center bg-gold-500 text-onyx-900 px-7 py-3.5 lg:px-10 text-[11px] tracking-[0.2em] uppercase w-full sm:w-auto min-h-[48px] font-semibold">
        {{ section.settings.hero_cta_text | default: 'View Collection' }}
      </a>
      <a href="#showroom" class="btn-outline inline-flex items-center justify-center gap-2 border border-gold-500/30 text-gold-400 px-7 py-3.5 lg:px-9 text-[11px] tracking-[0.2em] uppercase w-full sm:w-auto min-h-[48px] font-medium">
        <span class="material-symbols-outlined text-sm">storefront</span> Visit Showroom
      </a>
    </div>

    <p class="hero-enter hero-delay-5 text-sand-200/25 text-[10px] tracking-[0.25em] uppercase mt-6 sm:mt-8 font-sans">Trusted by customers across Virudhachalam</p>

    <div class="hero-enter hero-delay-5 mt-8 sm:mt-14 flex flex-col items-center gap-2 opacity-30">
      <span class="text-[9px] tracking-[0.3em] uppercase text-sand-300 font-sans">Scroll</span>
      <div class="w-[1px] h-8 bg-gradient-to-b from-gold-500/60 to-transparent"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "default": "Make Your Home Look Beautiful",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "hero_subheading",
      "default": "with Premium Decor.",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "default": "Furniture, Plants, Fountains & Stylish Decor — at our showroom in Virudhachalam.",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "hero_cta_text",
      "default": "View Collection",
      "label": "CTA Button Text"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "default": "/collections",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}