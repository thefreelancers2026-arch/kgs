{% comment %}
  Section: Showroom / About
  KGS Home Decors - Premium Dark Luxury Theme
{% endcomment %}

<section id="showroom" class="py-20 sm:py-28 lg:py-36 overflow-hidden bg-onyx-800">
  <div class="relative h-[1px] mb-20 sm:mb-28"><div class="section-glow top-0"></div></div>
  <div class="max-w-[1400px] mx-auto px-5 sm:px-6 md:px-12 relative">
    <div class="flex flex-col lg:flex-row items-center gap-10 sm:gap-14 lg:gap-0">
      <div class="w-full lg:w-7/12 z-0 reveal">
        <div class="relative aspect-[4/3] overflow-hidden shadow-2xl">
          {% if section.settings.showroom_image != blank %}
            <img src="{{ section.settings.showroom_image | image_url: width: 1000 }}" loading="lazy" class="w-full h-full object-cover opacity-75 hover:opacity-90 transition-opacity duration-1000" alt="KGS Home Decors showroom in Virudhachalam">
          {% else %}
            <img src="{{ 'showroom_indian.png' | asset_url }}" loading="lazy" class="w-full h-full object-cover opacity-75 hover:opacity-90 transition-opacity duration-1000" alt="KGS Home Decors showroom in Virudhachalam">
          {% endif %}
          <div class="absolute inset-0 border border-gold-500/10 m-3 sm:m-5 pointer-events-none" style="box-shadow: inset 0 0 40px rgba(212,175,55,0.04);"></div>
        </div>
      </div>

      <div class="w-full lg:w-6/12 lg:-ml-20 z-10 reveal reveal-delay-2">
        <div class="bg-onyx-900 p-8 sm:p-12 lg:p-16 border border-onyx-600/50 shadow-2xl relative">
          <div class="absolute top-0 left-0 w-10 h-[1px] bg-gradient-to-r from-gold-500 to-transparent"></div>
          <div class="absolute top-0 left-0 w-[1px] h-10 bg-gradient-to-b from-gold-500 to-transparent"></div>
          <div class="absolute bottom-0 right-0 w-10 h-[1px] bg-gradient-to-l from-gold-500/50 to-transparent"></div>
          <div class="absolute bottom-0 right-0 w-[1px] h-10 bg-gradient-to-t from-gold-500/50 to-transparent"></div>

          <p class="text-gold-500 text-[10px] tracking-[0.4em] uppercase mb-5 font-sans font-medium">Our Showroom · Virudhachalam</p>
          <h2 class="text-3xl sm:text-4xl lg:text-[2.8rem] font-display font-medium text-white mb-6 sm:mb-8 leading-[1.1]">{{ section.settings.showroom_title | default: 'Beautiful Decor for Every Home.' }}</h2>
          <div class="text-sand-200/70 font-light leading-[1.8] mb-6 text-[15px]">
            {{ section.settings.showroom_content | default: '<p>At KGS Home Decors, Virudhachalam, explore a wide range of stylish decor items. Visit our showroom and choose what fits your home perfectly.</p>' }}
          </div>
          <p class="text-gold-400/60 font-display italic text-lg mb-8 sm:mb-10 leading-[1.7]">
            Visit once — you'll definitely find something you love.
          </p>
          
          <ul class="space-y-5 mb-10 sm:mb-12">
            <li class="flex items-center gap-4">
              <span class="material-symbols-outlined text-gold-500 text-xl" style="font-variation-settings: 'FILL' 1;">storefront</span>
              <span class="text-white/80 font-light tracking-wide text-sm">Walk-in Showroom in Virudhachalam</span>
            </li>
            <li class="flex items-center gap-4">
              <span class="material-symbols-outlined text-gold-500 text-xl" style="font-variation-settings: 'FILL' 1;">verified</span>
              <span class="text-white/80 font-light tracking-wide text-sm">Premium Quality at Honest Prices</span>
            </li>
          </ul>

          <a href="#contact" class="btn-outline inline-flex items-center gap-3 text-gold-400 uppercase tracking-[0.15em] text-[11px] font-semibold pb-2 border-b border-gold-500/25 hover:border-gold-500 hover:text-white transition-all duration-500 min-h-[44px]">
            Visit Our Showroom <span class="material-symbols-outlined text-base">arrow_right_alt</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Showroom Section",
  "tag": "section",
  "class": "section-showroom",
  "settings": [
    {
      "type": "image_picker",
      "id": "showroom_image",
      "label": "Showroom Image"
    },
    {
      "type": "text",
      "id": "showroom_title",
      "default": "Beautiful Decor for Every Home.",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "showroom_content",
      "default": "<p>At KGS Home Decors, Virudhachalam, explore a wide range of stylish decor items. Visit our showroom and choose what fits your home perfectly.</p>",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "Showroom Section"
    }
  ]
}
{% endschema %}