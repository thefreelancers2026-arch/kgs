{% comment %}
  Section: Floating Action Buttons
  KGS Home Decors - Premium Dark Luxury Theme
  WhatsApp, Cart, Wishlist buttons
{% endcomment %}

{% style %}
  .fab-btn {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 10, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(212, 175, 55, 0.2);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.02);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    position: relative;
  }
  .fab-btn:hover {
    border-color: rgba(212, 175, 55, 0.5);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 20px rgba(212, 175, 55, 0.12);
    transform: translateY(-2px);
  }
  .fab-btn:active { transform: translateY(0) scale(0.96); }
  .fab-whatsapp {
    width: 52px;
    height: 52px;
    background: #D4AF37;
    border: 1px solid rgba(212, 175, 55, 0.6);
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.25), 0 0 0 1px rgba(255,255,255,0.05);
  }
  .fab-whatsapp:hover {
    background: #E5C76B;
    box-shadow: 0 4px 25px rgba(212, 175, 55, 0.35), 0 0 20px rgba(212, 175, 55, 0.15);
  }
  .fab-call {
    width: 48px;
    height: 48px;
  }
  .fab-wishlist {
    width: 44px;
    height: 44px;
    background: rgba(10, 10, 10, 0.7);
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .fab-wishlist:hover {
    border-color: rgba(212, 175, 55, 0.3);
  }
  .wish-badge {
    position: absolute;
    top: -3px;
    right: -3px;
    background: #D4AF37;
    color: #0A0A0A;
    font-size: 9px;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #0A0A0A;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .wishlist-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 0;
  }
  @media (min-width: 640px) {
    .wishlist-modal-overlay {
      align-items: center;
      padding: 16px;
    }
  }
  .wishlist-modal-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .wishlist-modal {
    background: #111111;
    border: 1px solid rgba(212, 175, 55, 0.1);
    border-radius: 20px 20px 0 0;
    width: 100%;
    max-width: 100%;
    max-height: 92vh;
    overflow-y: auto;
    box-shadow: 0 -10px 60px rgba(0,0,0,0.85), 0 0 80px rgba(212, 175, 55, 0.04);
    transform: translateY(100%);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (min-width: 640px) {
    .wishlist-modal {
      border-radius: 20px;
      max-width: 440px;
      max-height: 88vh;
      transform: translateY(24px) scale(0.96);
      box-shadow: 0 50px 100px rgba(0,0,0,0.85), 0 0 80px rgba(212, 175, 55, 0.04);
    }
  }
  .wishlist-modal-overlay.open .wishlist-modal {
    transform: translateY(0) scale(1);
  }
  .wishlist-modal::-webkit-scrollbar { width: 3px; }
  .wishlist-modal::-webkit-scrollbar-track { background: transparent; }
  .wishlist-modal::-webkit-scrollbar-thumb { background: #252525; border-radius: 2px; }
{% endstyle %}

<div class="fixed bottom-5 right-4 sm:bottom-8 sm:right-6 md:right-10 z-50 flex flex-col items-end gap-[10px] sm:gap-3" id="fabContainer">
  <div class="flex items-center gap-[10px] sm:gap-3 flex-row sm:flex-col" id="fabEcommerceGroup">
    <button class="fab-btn hidden" id="fabCart" aria-label="Open Cart" style="background: rgba(26,26,26,0.9); border: 1px solid rgba(212,175,55,0.2);">
      <span class="material-symbols-outlined text-gold-500/90 text-[18px]">shopping_cart</span>
      <span class="wish-badge hidden" id="fabCartBadge" style="background: #D4AF37; color: #0A0A0A;">0</span>
    </button>
    <button class="fab-btn fab-wishlist hidden" id="fabWishlist" aria-label="Open Wishlist">
      <span class="material-symbols-outlined text-gold-500/70 text-[18px]" style="font-variation-settings: 'FILL' 1;">favorite</span>
      <span class="wish-badge hidden" id="fabWishBadge">0</span>
    </button>
  </div>
  <div class="flex items-center gap-[10px] sm:gap-3 flex-row sm:flex-col" id="fabContactGroup">
    <a href="https://wa.me/{{ settings.contact_whatsapp | default: '919789182921' }}" target="_blank" class="fab-btn fab-whatsapp" aria-label="WhatsApp">
      <svg class="w-[20px] h-[20px] fill-current text-onyx-900" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51h-.57c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </a>
  </div>
</div>

<div class="wishlist-modal-overlay" id="wishlistModal">
  <div class="wishlist-modal">
    <div class="sm:hidden flex justify-center pt-3 pb-1">
      <div class="w-10 h-1 rounded-full bg-onyx-600/60"></div>
    </div>
    <div class="flex justify-between items-start p-6 pb-4 border-b" style="border-color: rgba(212,175,55,0.08);">
      <div>
        <h3 class="text-lg font-display font-medium text-white mb-1">Your Wishlist</h3>
        <p class="text-sand-200/40 text-[11px] tracking-[0.05em] mt-1 font-sans leading-[1.6]">Review your saved premium items and proceed to checkout</p>
      </div>
      <button id="closeWishlistModal" class="text-sand-200/40 hover:text-white transition-colors duration-500 min-h-[44px] min-w-[44px] flex items-center justify-center rounded-full hover:bg-onyx-700/40 flex-shrink-0 ml-2">
        <span class="material-symbols-outlined text-lg">close</span>
      </button>
    </div>
    <div id="wishlistItems" class="p-5 space-y-2.5 max-h-[200px] overflow-y-auto">
      <p class="text-sand-200/30 text-sm text-center py-6 font-light" id="emptyWishMsg">No items selected yet.<br><span class="text-[10px] tracking-wider uppercase mt-1 block">Tap ♡ on any product</span></p>
    </div>
    <div class="px-5 pb-2">
      <div class="border-t pt-4 flex justify-between items-center" style="border-color: rgba(212,175,55,0.06);">
        <p class="text-sand-200/50 text-xs tracking-[0.1em] uppercase font-sans font-medium">Subtotal</p>
        <p class="text-gold-500 text-lg font-medium" id="wishTotal">₹0</p>
      </div>
    </div>
    <div class="p-5 pt-4">
      <a href="{{ routes.cart_url }}" class="btn-primary w-full bg-gold-400 hover:bg-gold-500 text-onyx-900 py-4 rounded-lg text-[11px] uppercase tracking-[0.2em] font-bold flex justify-center items-center gap-2.5 min-h-[52px]">
        <span class="material-symbols-outlined text-[18px]">lock</span> Secure Checkout
      </a>
    </div>
  </div>
</div>

<div class="wishlist-modal-overlay" id="cartModal">
  <div class="wishlist-modal">
    <div class="sm:hidden flex justify-center pt-3 pb-1">
      <div class="w-10 h-1 rounded-full bg-onyx-600/60"></div>
    </div>
    <div class="flex justify-between items-start p-6 pb-4 border-b" style="border-color: rgba(212,175,55,0.08);">
      <div>
        <h3 class="text-lg font-display font-medium text-white mb-1">Your Shopping Cart</h3>
        <p class="text-sand-200/40 text-[11px] tracking-[0.05em] mt-1 font-sans leading-[1.6]">Ready to proceed to checkout?</p>
      </div>
      <button id="closeCartModal" class="text-sand-200/40 hover:text-white transition-colors duration-500 min-h-[44px] min-w-[44px] flex items-center justify-center rounded-full hover:bg-onyx-700/40 flex-shrink-0 ml-2">
        <span class="material-symbols-outlined text-lg">close</span>
      </button>
    </div>
    <div id="cartItems" class="p-5 space-y-3 max-h-[300px] overflow-y-auto">
      <p class="text-sand-200/30 text-sm text-center py-8 font-light" id="emptyCartMsg">Your cart is empty.<br><span class="text-[10px] tracking-wider uppercase mt-1 block">Add premium items to continue</span></p>
    </div>
    <div class="px-5 pb-2">
      <div class="border-t pt-4 flex justify-between items-center" style="border-color: rgba(212,175,55,0.06);">
        <p class="text-sand-200/50 text-xs tracking-[0.1em] uppercase font-sans font-medium">Subtotal</p>
        <p class="text-gold-500 text-lg font-medium" id="cartTotal">₹0</p>
      </div>
    </div>
    <div class="p-5 pt-4">
      <a href="{{ routes.checkout_url }}" class="btn-primary w-full bg-gold-400 hover:bg-gold-500 text-onyx-900 py-4 rounded-lg text-[11px] uppercase tracking-[0.2em] font-bold flex justify-center items-center gap-2.5 min-h-[52px]">
        <span class="material-symbols-outlined text-[18px]">lock</span> Secure Checkout
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Floating Action Buttons",
  "tag": "section",
  "class": "section-fab",
  "presets": [
    {
      "name": "Floating Action Buttons"
    }
  ]
}
{% endschema %}