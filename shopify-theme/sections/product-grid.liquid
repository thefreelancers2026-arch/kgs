{% comment %}
  Section: Product Grid
  KGS Home Decors - Premium Dark Luxury Theme
  Displays products with category filtering
{% endcomment %}

{% style %}
  .product-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.04);
    transition: border-color 0.8s ease, box-shadow 0.8s ease;
  }
  .product-card:hover {
    border-color: rgba(212, 175, 55, 0.15);
    box-shadow: 0 0 40px rgba(212, 175, 55, 0.04), 0 20px 60px rgba(0,0,0,0.3);
  }
  .product-card img { 
    transition: transform 2s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.2s ease; 
  }
  .product-card:hover img { 
    transform: scale(1.05); 
  }
  .gold-line {
    height: 1px;
    width: 3.5rem;
    background: linear-gradient(90deg, #D4AF37, rgba(212, 175, 55, 0.3));
    box-shadow: 0 0 8px rgba(212, 175, 55, 0.2);
  }
  .category-tab {
    white-space: nowrap;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 10px 22px;
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    background: rgba(255, 255, 255, 0.015);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(213, 206, 196, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;
  }
  .category-tab:hover {
    color: var(--color-sand-50);
    border-color: rgba(212, 175, 55, 0.2);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-1px);
  }
  .category-tab.active {
    color: var(--color-onyx-900);
    background: var(--color-gold-500);
    border-color: var(--color-gold-500);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.2);
    font-weight: 600;
    transform: translateY(0);
  }
  .cat-scroll-container {
    position: relative;
  }
  .cat-scroll-container::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 60px;
    background: linear-gradient(to right, transparent, #0A0A0A);
    pointer-events: none;
  }
  .cat-scroll::-webkit-scrollbar { display: none; }
  .cat-scroll { -ms-overflow-style: none; scrollbar-width: none; }
  .section-glow {
    position: absolute;
    width: 50%;
    height: 1px;
    left: 25%;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,0.15), transparent);
  }
  .wish-active .material-symbols-outlined { 
    font-variation-settings: 'FILL' 1, 'wght' 200, 'GRAD' 0, 'opsz' 24; 
    color: #D4AF37 !important; 
    transform: scale(1.15);
    filter: drop-shadow(0 0 6px rgba(212, 175, 55, 0.4));
  }
  .fade-in-scale {
    opacity: 0;
    animation: fadeInBlur 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeInBlur {
    0% { opacity: 0; transform: scale(0.96) translateY(20px); filter: blur(8px); }
    100% { opacity: 1; transform: scale(1) translateY(0); filter: blur(0); }
  }
  @media (max-width: 768px) {
    .product-grid {
      display: flex !important;
      flex-wrap: nowrap !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      gap: 16px !important;
      padding-bottom: 24px !important;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
    }
    .product-grid > div {
      min-width: 85vw !important;
      max-width: 85vw !important;
      scroll-snap-align: center;
      flex-shrink: 0;
    }
  }
{% endstyle %}

<section id="collections" class="py-16 sm:py-28 lg:py-36 px-4 sm:px-6 md:px-12 bg-onyx-900">
  <div class="max-w-[1400px] mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-14 sm:mb-20 gap-6 reveal">
      <div>
        <p class="text-gold-500 text-[10px] tracking-[0.4em] uppercase mb-4 font-sans font-medium">Our Collection</p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-display font-medium text-white mb-3 leading-[1.1]">Handpicked for<br class="hidden sm:block"> Your Home</h2>
        <div class="gold-line mt-4"></div>
      </div>
      <p class="text-sand-300 font-light max-w-sm text-sm leading-[1.75] text-left md:text-right">
        Everything to make your home beautiful — furniture, clocks, plants, lighting &amp; more. Available at our Virudhachalam showroom.
      </p>
    </div>

    <div class="mb-12 w-full overflow-hidden reveal cat-scroll-container">
      <div class="cat-scroll flex gap-3 sm:gap-4 overflow-x-auto pb-6 pt-2 px-1 items-center" id="categoryTabs">
        <button class="category-tab active" data-filter="All">All</button>
        {% for collection in collections %}
          <button class="category-tab" data-filter="{{ collection.title }}">{{ collection.title }}</button>
        {% endfor %}
        <button class="category-tab" data-filter="Sofas & Seating">Sofas</button>
        <button class="category-tab" data-filter="Office Chairs & Tables">Office Desks</button>
        <button class="category-tab" data-filter="Wall Clocks">Clocks</button>
        <button class="category-tab" data-filter="Photo Frames">Frames</button>
        <button class="category-tab" data-filter="Decorative Statues">Statues</button>
        <button class="category-tab" data-filter="Water Fountains">Fountains</button>
        <button class="category-tab" data-filter="Artificial Plants">Plants</button>
        <button class="category-tab" data-filter="LED Chandeliers">Lighting</button>
      </div>
    </div>

    <div id="dynamic-product-grid" class="product-grid grid grid-cols-1 md:grid-cols-12 gap-4 sm:gap-5 lg:gap-6 min-h-[400px]">
      {% comment %} Products rendered via Shopify or JS {% endcomment %}
      {% if section.settings.collection != blank %}
        {% for product in collections[section.settings.collection].products limit: 12 %}
          <div class="md:col-span-4 group relative product-card bg-onyx-800 rounded-sm fade-in-scale">
            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | image_url: width: 600 }}" loading="lazy" class="w-full h-[320px] sm:h-[420px] lg:h-[460px] object-cover opacity-60 group-hover:opacity-85" alt="{{ product.title }}">
              <div class="absolute inset-0 bg-gradient-to-t from-onyx-900 via-transparent to-transparent opacity-80 group-hover:opacity-55 transition-opacity duration-1000"></div>
            </a>
            
            <button class="wishlist-btn absolute top-4 left-4 z-20 p-2.5 transition-all duration-500 group/wish flex items-center justify-center rounded-full hover:bg-onyx-900/50 min-h-[44px] min-w-[44px]" aria-label="Add to Wishlist" data-product="{{ product.title }}" data-variant-id="{{ product.variants.first.id }}">
              <span class="material-symbols-outlined text-white/40 group-hover/wish:text-gold-500 text-[24px] transition-all duration-500">favorite</span>
            </button>
            
            <div class="absolute bottom-6 sm:bottom-8 left-6 sm:left-8">
              <h3 class="text-xl sm:text-2xl font-display font-medium text-white mb-1">{{ product.title }}</h3>
              <p class="text-gold-400 text-[10px] tracking-[0.15em] uppercase font-sans">{{ product.price | money }}</p>
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% comment %} Demo products for preview {% endcomment %}
        {% assign demo_products = 'Velvet 3-Seater Sofa,Premium Lounger,Executive Mesh Chair,Antique Sweep Clock,Collage Frame Set,Golden Buddha,Indoor Table Fountain,Bonsai Tree Plant,Crystal Tier Chandelier' | split: ',' %}
        {% assign demo_prices = '₹24,999,₹18,500,₹4,200,₹2,100,₹1,200,₹3,200,₹5,600,₹950,₹18,500' | split: ',' %}
        {% assign demo_images = 'sofa_img,sofa_img,office_chair_img,wall_clock_img,photo_frame_img,statue_img,fountain_img,plant_indian,chandelier_img' | split: ',' %}
        
        {% for demo_product in demo_products %}
          <div class="md:col-span-4 group relative product-card bg-onyx-800 rounded-sm fade-in-scale" style="animation-delay: {{ forloop.index0 | times: 0.08 }}s;">
            <img src="{{ demo_images[forloop.index0] | append: '.png' | asset_url }}" loading="lazy" class="w-full h-[320px] sm:h-[420px] lg:h-[460px] object-cover opacity-60 group-hover:opacity-85" alt="{{ demo_product }}">
            <div class="absolute inset-0 bg-gradient-to-t from-onyx-900 via-transparent to-transparent opacity-80 group-hover:opacity-55 transition-opacity duration-1000"></div>
            
            <button class="wishlist-btn absolute top-4 left-4 z-20 p-2.5 transition-all duration-500 group/wish flex items-center justify-center rounded-full hover:bg-onyx-900/50 min-h-[44px] min-w-[44px]" aria-label="Add to Wishlist" data-product="{{ demo_product }}">
              <span class="material-symbols-outlined text-white/40 group-hover/wish:text-gold-500 text-[24px] transition-all duration-500">favorite</span>
            </button>
            
            <button class="cart-btn absolute top-[64px] left-4 z-20 p-2.5 transition-all duration-500 group/cart flex items-center justify-center rounded-full hover:bg-onyx-900/50 min-h-[44px] min-w-[44px]" aria-label="Add to Cart" data-product="{{ demo_product }}" data-price="{{ demo_prices[forloop.index0] }}">
              <span class="material-symbols-outlined text-white/40 group-hover/cart:text-gold-500 text-[22px] transition-all duration-500 cart-icon">shopping_cart</span>
            </button>
            
            <div class="absolute bottom-6 sm:bottom-8 left-6 sm:left-8">
              <h3 class="text-xl sm:text-2xl font-display font-medium text-white mb-1">{{ demo_product }}</h3>
              <p class="text-gold-400 text-[10px] tracking-[0.15em] uppercase font-sans">{{ demo_prices[forloop.index0] }}</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="md:hidden flex items-center justify-center mt-8 mb-4 reveal">
      <div class="inline-flex items-center gap-4 px-6 py-2.5 rounded-full border border-gold-500/20 bg-onyx-900/60 backdrop-blur-xl shadow-[0_0_20px_rgba(212,175,55,0.05)] relative overflow-hidden">
        <span class="material-symbols-outlined text-gold-500/80 text-[15px] animate-pulse">arrow_back</span>
        <span class="text-[9px] tracking-[0.4em] uppercase text-gold-400 font-sans font-medium">Swipe Collection</span>
        <span class="material-symbols-outlined text-gold-500/80 text-[15px] animate-pulse" style="animation-delay: 1s;">arrow_forward</span>
      </div>
    </div>

    <div class="text-center mt-16 sm:mt-24 reveal">
      <p class="text-sand-200/30 text-[10px] tracking-[0.3em] uppercase mb-3 font-sans">Premium Look · Affordable Prices</p>
      <p class="text-sand-200/20 text-[10px] tracking-[0.2em] uppercase mb-8 font-sans">100% Secure Checkout &middot; Express Delivery</p>
      <a href="{{ routes.cart_url }}" class="btn-primary inline-flex items-center justify-center gap-2.5 bg-gold-500 text-onyx-900 px-8 md:px-10 py-4 text-[11px] font-semibold tracking-[0.2em] uppercase min-h-[52px] w-full sm:w-auto max-w-sm mx-auto">
        <span class="material-symbols-outlined text-sm">shopping_cart_checkout</span> View Your Cart
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "class": "section-product-grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 12,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}