{% comment %}
  Section: Main Product Page
  KGS Home Decors - Premium Dark Luxury Theme
{% endcomment %}

{% style %}
  .product-main {
    background: var(--color-onyx-900);
    min-height: 100vh;
  }
  .product-gallery {
    position: relative;
  }
  .product-gallery img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  .product-info {
    padding: 2rem;
  }
  .product-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 500;
    color: var(--color-sand-50);
    margin-bottom: 1rem;
  }
  .product-price {
    font-size: 1.5rem;
    color: var(--color-gold-500);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .product-description {
    color: var(--color-sand-200);
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .product-form {
    margin-bottom: 2rem;
  }
  .variant-swatch {
    display: inline-block;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    margin: 0 4px 8px 0;
  }
  .variant-swatch.active {
    border-color: var(--color-gold-500);
  }
  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25D366;
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .whatsapp-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
  }
{% endstyle %}

<section class="product-main pt-24 pb-16">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      
      {% comment %} Product Gallery {% endcomment %}
      <div class="product-gallery">
        <div class="relative aspect-[4/3] overflow-hidden bg-onyx-800">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 800 }}" 
                 alt="{{ product.title }}"
                 class="w-full h-full object-cover"
                 id="productImage">
          {% else %}
            <img src="{{ 'sofa_img.png' | asset_url }}" 
                 alt="{{ product.title }}"
                 class="w-full h-full object-cover">
          {% endif %}
        </div>
        
        {% if product.images.size > 1 %}
          <div class="flex gap-3 mt-4 overflow-x-auto">
            {% for image in product.images %}
              <button class="thumbnail-btn flex-shrink-0 w-20 h-20 border-2 border-onyx-600 hover:border-gold-500 transition-colors" 
                      onclick="document.getElementById('productImage').src='{{ image | image_url: width: 800 }}'">
                <img src="{{ image | image_url: width: 200 }}" class="w-full h-full object-cover" alt="">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>
      
      {% comment %} Product Info {% endcomment %}
      <div class="product-info">
        <h1 class="product-title">{{ product.title }}</h1>
        
        <p class="product-price">
          {% if product.price_varies %}
            From {{ product.price | money }}
          {% else %}
            {{ product.price | money }}
          {% endif %}
          
          {% if product.compare_at_price > product.price %}
            <span class="text-sand-300 line-through ml-3">{{ product.compare_at_price | money }}</span>
          {% endif %}
        </p>
        
        <div class="product-description">
          {{ product.description }}
        </div>
        
        {% comment %} Add to Cart Form {% endcomment %}
        {% form 'product', product, class: 'product-form' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          {% if product.variants.size > 1 %}
            <div class="variant-options mb-6">
              <label class="text-sand-300 text-sm uppercase tracking-wider mb-3 block">Options</label>
              <div class="flex flex-wrap gap-2">
                {% for variant in product.variants %}
                  <button type="button" 
                          class="variant-swatch {% if variant == product.selected_or_first_available_variant %}active{% endif %}"
                          data-variant-id="{{ variant.id }}"
                          data-variant-price="{{ variant.price }}">
                    {{ variant.title }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endif %}
          
          <div class="flex flex-col sm:flex-row gap-3">
            <button type="submit" name="add" class="btn-primary flex-1 bg-gold-500 text-onyx-900 px-8 py-4 uppercase tracking-[0.2em] font-semibold min-h-[52px]">
              <span class="material-symbols-outlined mr-2">shopping_cart</span>
              Add to Cart
            </button>
            
            <button type="button" class="wishlist-btn wishlist-toggle px-6 py-4 border border-onyx-600 hover:border-gold-500 transition-colors min-h-[52px]" data-product="{{ product.title }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
              <span class="material-symbols-outlined text-gold-400">favorite_border</span>
            </button>
          </div>
        {% endform %}
        
        {% comment %} WhatsApp Order Button {% endcomment %}
        <a href="https://wa.me/{{ settings.contact_whatsapp | default: '919789182921' }}?text=I'm interested in {{ product.title | url_encode }} - {{ product.price | money }}" 
           target="_blank"
           class="whatsapp-btn mt-4">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51h-.57c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Order via WhatsApp
        </a>
        
        {% comment %} Product Details {% endcomment %}
        <div class="mt-8 pt-8 border-t border-onyx-700">
          <div class="flex items-center gap-4 mb-4">
            <span class="material-symbols-outlined text-gold-500">storefront</span>
            <span class="text-sand-200">Available at KGS Showroom, Virudhachalam</span>
          </div>
          <div class="flex items-center gap-4 mb-4">
            <span class="material-symbols-outlined text-gold-500">local_shipping</span>
            <span class="text-sand-200">Delivery across Tamil Nadu</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-gold-500">verified</span>
            <span class="text-sand-200">Premium Quality Guaranteed</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Page",
  "tag": "section",
  "class": "section-product-main",
  "presets": [
    {
      "name": "Product Page"
    }
  ]
}
{% endschema %}