{% endcomment %}

{% style %}
  .stroke-text { 
    -webkit-text-stroke: 1px rgba(213, 206, 196, 0.5); 
    -webkit-text-fill-color: transparent; 
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
{% endstyle %}

